{
  "name": "swap",
  "version": "0.1.0",
  "description": "Supervisor that swaps between Claude Code and Codex CLI on rate-limit/quota errors",
  "type": "module",
  "bin": {
    "swap": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "demo": "node dist/cli.js demo",
    "handoff:preview": "npm run build && node scripts/handoff-preview.mjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^9.5.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
